# 경마 BMED 분석기 환경변수 예시 (.env.example)
# ⚠️ 실제 값은 .env 파일에 넣으세요. .env 는 .gitignore 로 제외되어 GitHub 에 올라가지 않습니다.
# Railway 배포 시엔 이 값들을 Railway 대시보드의 Variables 에 등록하세요(.env 업로드 금지).

# 필수 — Anthropic Claude API 키
ANTHROPIC_API_KEY=여기에_키_입력

# 실행 환경 (production 이면 debug 비활성)
FLASK_ENV=production

# 포트 (Railway 는 PORT 를 자동 주입 — 로컬은 미설정 시 8011)
# PORT=8011

# 선택 — 데이터 자동백업 주기(시간, 기본 6)
# BACKUP_INTERVAL_HOURS=6

# 선택 — 학습일지 자동생성 시각(0~23시, 기본 22)
# DAILY_LEARNING_HOUR=22
