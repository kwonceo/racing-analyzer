{
  "manifest_version": 3,
  "name": "경마 배당 자동수집기 (keiba.go.jp)",
  "version": "1.0.0",
  "description": "keiba.go.jp 배당판에서 단승/복승 배당을 자동으로 읽어 경마분석서버(127.0.0.1:8011)로 전송합니다.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.keiba.go.jp/*",
    "http://127.0.0.1:8011/*",
    "http://localhost:8011/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.keiba.go.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "경마 배당 자동수집기",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
