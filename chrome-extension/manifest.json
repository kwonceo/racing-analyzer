{
  "manifest_version": 3,
  "name": "경마 배당 자동수집기 (keiba.go.jp)",
  "version": "1.5.2",
  "description": "keiba.go.jp·사설 배당판(asyukk 등)에서 단승/복승 배당과 결과를 사이트 자동감지로 수집·전송하고, 모든 탭 상단에 경주 카운트다운 타이머를 표시합니다. 범용 매트릭스 파서 + 검증 + 미리보기 지원.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.keiba.go.jp/*",
    "*://asyukk34.qwqwd25.net/*",
    "*://*.qwqwd25.net/*",
    "http://127.0.0.1:8011/*",
    "http://localhost:8011/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.keiba.go.jp/*", "*://asyukk34.qwqwd25.net/*", "*://*.qwqwd25.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["timer.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "경마 배당 자동수집기",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
